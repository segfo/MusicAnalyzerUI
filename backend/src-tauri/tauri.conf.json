{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Music Analyzer",
  "version": "0.1.0",
  "identifier": "com.tauri.dev",
  "build": {
    "frontendDist": "../../frontend/dist",
    "devUrl": "http://localhost:8080",
    "beforeDevCommand": {
      "script": "trunk serve",
      "cwd": "../../frontend"
    },
    "beforeBuildCommand": {
      "script": "trunk build --release",
      "cwd": "../../frontend"
    }
  },
  "app": {
    "windows": [
      {
        "title": "Music Analyzer",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
